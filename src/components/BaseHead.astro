---
import '../styles/global.css';
import { hrefFavicon, hrefFont } from '../utils/sitePaths';
import {
	SITE_TITLE,
	SITE_DESCRIPTION,
	SITE_URL,
	CONTACT,
	GITHUB_USERNAME,
} from '../consts';
import type { SeoOptions } from '../types/seo';

interface Props {
	title: string;
	description: string;
	seo?: SeoOptions;
}

const pathname = Astro.url.pathname;
const { title, description, seo } = Astro.props;

const canonicalURL = new URL(pathname, Astro.site);
const canonicalHref = canonicalURL.href;

const siteOrigin = SITE_URL.replace(/\/$/, '');

/** Default Open Graph / Twitter image (see `public/og-default.png`). */
const OG_DEFAULT_PATH = '/og-default.png';
const OG_DEFAULT_WIDTH = 1376;
const OG_DEFAULT_HEIGHT = 768;

function resolveOgImageUrl(origin: string, ogImage?: string): string {
	if (!ogImage) {
		return `${origin}${OG_DEFAULT_PATH}`;
	}
	if (ogImage.startsWith('https://') || ogImage.startsWith('http://')) {
		return ogImage;
	}
	const path = ogImage.startsWith('/') ? ogImage : `/${ogImage}`;
	return `${origin}${path}`;
}

const ogImageAbs = resolveOgImageUrl(siteOrigin, seo?.ogImage);
const usesDefaultOgImage = !seo?.ogImage;
const ogImageWidth = usesDefaultOgImage
	? OG_DEFAULT_WIDTH
	: (seo?.ogImageWidth ?? undefined);
const ogImageHeight = usesDefaultOgImage
	? OG_DEFAULT_HEIGHT
	: (seo?.ogImageHeight ?? undefined);

const iconHref = hrefFavicon(pathname);
const fontRegular = hrefFont(pathname, 'atkinson-regular.woff');
const fontBold = hrefFont(pathname, 'atkinson-bold.woff');
const fontFaceInline = `<style>@font-face{font-family:Atkinson;src:url('${fontRegular}')format('woff');font-weight:400;font-style:normal;font-display:swap}@font-face{font-family:Atkinson;src:url('${fontBold}')format('woff');font-weight:700;font-style:normal;font-display:swap}</style>`;

const ogType = seo?.ogType ?? 'website';
const robotsContent = seo?.noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const sameAs: string[] = [`https://github.com/${GITHUB_USERNAME}`];
if (CONTACT.linkedin) sameAs.push(CONTACT.linkedin);

const personId = `${siteOrigin}/#person`;
const websiteId = `${siteOrigin}/#website`;

type JsonLdThing = Record<string, unknown>;

/** BreadcrumbList for nested routes (not emitted on home). */
function breadcrumbListForPath(
	path: string,
	origin: string,
	seoHeadline?: string,
): JsonLdThing | null {
	const trimmed = path.replace(/\/$/, '') || '/';
	const segments = trimmed === '/' ? [] : trimmed.split('/').filter(Boolean);
	if (segments.length === 0) {
		return null;
	}

	const sectionTitles: Record<string, string> = {
		about: 'About',
		services: 'Services',
		contact: 'Contact',
		blog: 'Blog',
	};

	type Crumb = { name: string; item: string };
	const items: Crumb[] = [{ name: 'Home', item: `${origin}/` }];

	if (segments[0] === 'blog' && segments.length >= 2) {
		items.push({ name: 'Blog', item: `${origin}/blog/` });
		items.push({
			name: seoHeadline ?? 'Post',
			item: `${origin}/blog/${segments[1]}/`,
		});
	} else if (segments[0] === 'blog') {
		items.push({ name: 'Blog', item: `${origin}/blog/` });
	} else if (segments.length === 1 && sectionTitles[segments[0]]) {
		items.push({
			name: sectionTitles[segments[0]],
			item: `${origin}/${segments[0]}/`,
		});
	} else {
		return null;
	}

	if (items.length < 2) {
		return null;
	}

	return {
		'@type': 'BreadcrumbList',
		itemListElement: items.map((c, i) => ({
			'@type': 'ListItem',
			position: i + 1,
			name: c.name,
			item: c.item,
		})),
	};
}

const jsonLdGraph: JsonLdThing[] = [
	{
		'@type': 'WebSite',
		'@id': websiteId,
		url: `${siteOrigin}/`,
		name: SITE_TITLE,
		description: SITE_DESCRIPTION,
		inLanguage: 'en-US',
		publisher: { '@id': personId },
	},
	{
		'@type': 'Person',
		'@id': personId,
		name: SITE_TITLE,
		url: `${siteOrigin}/`,
		email: CONTACT.email,
		jobTitle: 'Systems engineer and developer',
		sameAs,
	},
];

if (ogType === 'article' && seo?.publishedTime) {
	const headline = seo.headline ?? title;
	const modified = seo.modifiedTime ?? seo.publishedTime;
	jsonLdGraph.push({
		'@type': 'BlogPosting',
		headline,
		description,
		datePublished: seo.publishedTime,
		dateModified: modified,
		author: { '@type': 'Person', '@id': personId },
		publisher: { '@type': 'Person', '@id': personId },
		mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalHref },
		url: canonicalHref,
		image: ogImageAbs,
	});
}

const breadcrumbLd = breadcrumbListForPath(pathname, siteOrigin, seo?.headline);
if (breadcrumbLd) {
	jsonLdGraph.push(breadcrumbLd);
}

const structuredData = {
	'@context': 'https://schema.org',
	'@graph': jsonLdGraph,
};

const jsonLdRaw = JSON.stringify(structuredData);

const gaMeasurementId = 'G-P73TT5C3EQ';
---

<!-- Global Metadata -->
<meta charset="utf-8" />

<link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
<link rel="preconnect" href="https://www.google-analytics.com" crossorigin />
<link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

<!-- Google tag (gtag.js) -->
<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
<script is:inline define:vars={{ gaMeasurementId }}>
	window.dataLayer = window.dataLayer || [];
	function gtag() {
		dataLayer.push(arguments);
	}
	gtag('js', new Date());
	gtag('config', gaMeasurementId);
</script>
<meta
	name="viewport"
	content="width=device-width, initial-scale=1, viewport-fit=cover"
/>
<meta name="theme-color" content="#212529" />
<link rel="icon" type="image/svg+xml" href={iconHref} />
<meta name="generator" content={Astro.generator} />

<meta name="robots" content={robotsContent} />
<meta name="googlebot" content={robotsContent} />
<meta name="author" content={SITE_TITLE} />

<!-- Bootstrap 5 -->
<link
	href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
	rel="stylesheet"
	integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
	crossorigin="anonymous"
/>

<!-- Font preloads + @font-face (relative to current page URL) -->
<link rel="preload" href={fontRegular} as="font" type="font/woff" crossorigin />
<link rel="preload" href={fontBold} as="font" type="font/woff" crossorigin />
<Fragment set:html={fontFaceInline} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalHref} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalHref} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageAbs} />
{
	ogImageWidth && ogImageHeight && (
		<>
			<meta property="og:image:width" content={String(ogImageWidth)} />
			<meta property="og:image:height" content={String(ogImageHeight)} />
		</>
	)
}
<meta
	property="og:image:alt"
	content={`${SITE_TITLE} — systems engineer and developer (briangates.tech)`}
/>
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="en_US" />
{
	seo?.publishedTime && (
		<>
			<meta property="article:published_time" content={seo.publishedTime} />
			<meta property="article:author" content={SITE_TITLE} />
		</>
	)
}
{
	ogType === 'article' && seo?.publishedTime && (
		<meta
			property="article:modified_time"
			content={seo.modifiedTime ?? seo.publishedTime}
		/>
	)
}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalHref} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbs} />

<!-- Structured data (WebSite, Person, BlogPosting on articles) -->
<script type="application/ld+json" set:html={jsonLdRaw} />
