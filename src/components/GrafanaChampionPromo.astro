---
import { GRAFANA } from '../consts';
---

<div class="grafana-promo card border-0 shadow-sm overflow-hidden">
	<div class="card-body p-4 p-md-4">
		<div class="row align-items-center g-4">
			<div class="col-sm-auto text-center">
				<figure class="mb-0 grafana-promo__figure">
					<!-- Original character: Grafana-orange “metrics bot”, inspired by Grot — not official Grafana art -->
					<svg
						class="grafana-promo__bot"
						viewBox="0 0 128 148"
						xmlns="http://www.w3.org/2000/svg"
						aria-hidden="true"
						focusable="false"
					>
						<ellipse cx="64" cy="92" rx="48" ry="42" fill="#252525" />
						<ellipse cx="64" cy="82" rx="40" ry="34" fill="#343434" />
						<rect x="36" y="68" width="56" height="30" rx="5" fill="#141414" />
						<path
							d="M42 88 L54 76 L66 84 L78 70 L90 86"
							stroke="#f46800"
							stroke-width="3.5"
							fill="none"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
						<circle cx="52" cy="56" r="9" fill="#f46800" />
						<circle cx="76" cy="56" r="9" fill="#f46800" />
						<circle cx="54" cy="54" r="3.5" fill="#fff" />
						<circle cx="78" cy="54" r="3.5" fill="#fff" />
						<path
							d="M54 44 Q64 38 74 44"
							stroke="#f46800"
							stroke-width="2.5"
							fill="none"
							stroke-linecap="round"
						/>
						<line x1="64" y1="48" x2="64" y2="22" stroke="#f46800" stroke-width="4" stroke-linecap="round" />
						<circle cx="64" cy="16" r="7" fill="#f46800" />
						<ellipse cx="48" cy="126" rx="14" ry="9" fill="#2a2a2a" />
						<ellipse cx="80" cy="126" rx="14" ry="9" fill="#2a2a2a" />
					</svg>
					<figcaption class="small text-body-secondary mt-2 mb-0 px-1">
						A tiny metrics bot — channeling Grafana’s Grot energy
					</figcaption>
				</figure>
			</div>
			<div class="col">
				<p class="text-uppercase small fw-semibold text-primary mb-1 ls-wide">Community</p>
				<h2 class="h5 fw-bold mb-2">Grafana Champion</h2>
				<p class="text-body-secondary small mb-3 mb-md-4">
					I am part of the{' '}
					<a href={GRAFANA.champions} target="_blank" rel="noopener noreferrer">Grafana Champions</a>
					program — helping folks get more from observability, dashboards, and the open source ecosystem around
					<a href={GRAFANA.site} target="_blank" rel="noopener noreferrer">Grafana</a>.
				</p>
				<div class="d-flex flex-wrap gap-2">
					<a class="btn btn-sm btn-primary" href={GRAFANA.site} target="_blank" rel="noopener noreferrer">
						Grafana.com
					</a>
					<a
						class="btn btn-sm btn-outline-secondary"
						href={GRAFANA.champions}
						target="_blank"
						rel="noopener noreferrer"
					>
						Champions program
					</a>
				</div>
			</div>
		</div>
	</div>
</div>

<style>
	.grafana-promo {
		background: linear-gradient(135deg, #fafafa 0%, #f0f4f8 100%);
		border: 1px solid rgba(0, 0, 0, 0.06) !important;
	}
	.grafana-promo__figure {
		max-width: 11rem;
		margin-left: auto;
		margin-right: auto;
	}
	.grafana-promo__bot {
		width: 7.5rem;
		height: auto;
		display: block;
		margin: 0 auto;
		filter: drop-shadow(0 6px 12px rgba(244, 104, 0, 0.15));
	}
	.ls-wide {
		letter-spacing: 0.12em;
	}
</style>
