---
import { GRAFANA } from '../consts';
---

<div class="grafana-promo card border-0 shadow-sm overflow-hidden">
	<div class="card-body p-4 p-md-4">
		<div class="row align-items-center g-4">
			<div class="col-sm-auto text-center grafana-promo__brand">
				<a
					href={GRAFANA.champions}
					target="_blank"
					rel="noopener noreferrer"
					class="grafana-promo__logo-link d-inline-block"
				>
					<img
						class="grafana-promo__logo img-fluid"
						src={GRAFANA.championLogo}
						alt="Grafana Champion"
						width="625"
						height="622"
						loading="lazy"
						decoding="async"
					/>
				</a>
			</div>
			<div class="col">
				<p class="text-uppercase small fw-semibold text-primary mb-1 ls-wide">Community</p>
				<h2 class="h5 fw-bold mb-2">Grafana Champion</h2>
				<p class="text-body-secondary small mb-3 mb-md-4">
					I am part of the{' '}
					<a href={GRAFANA.champions} target="_blank" rel="noopener noreferrer">Grafana Champions</a>
					program — helping folks get more from observability, dashboards, and the open source ecosystem around
					<a href={GRAFANA.site} target="_blank" rel="noopener noreferrer">Grafana</a>.
				</p>
				<div class="d-flex flex-wrap gap-2">
					<a class="btn btn-sm btn-primary" href={GRAFANA.site} target="_blank" rel="noopener noreferrer">
						Grafana.com
					</a>
					<a
						class="btn btn-sm btn-outline-secondary"
						href={GRAFANA.champions}
						target="_blank"
						rel="noopener noreferrer"
					>
						Champions program
					</a>
				</div>
			</div>
		</div>
	</div>
</div>

<style>
	.grafana-promo {
		background: linear-gradient(135deg, #fafafa 0%, #f0f4f8 100%);
		border: 1px solid rgba(0, 0, 0, 0.06) !important;
	}
	.grafana-promo__brand {
		max-width: min(100%, 16rem);
		margin-left: auto;
		margin-right: auto;
	}
	.grafana-promo__logo-link {
		text-decoration: none;
		border-radius: 0.5rem;
		transition: transform 0.15s ease, filter 0.15s ease;
	}
	.grafana-promo__logo-link:hover {
		transform: scale(1.02);
		filter: brightness(1.03);
	}
	.grafana-promo__logo {
		display: block;
		margin: 0 auto;
		max-height: 14rem;
		width: auto;
		height: auto;
		object-fit: contain;
		filter: drop-shadow(0 4px 14px rgba(0, 0, 0, 0.08));
	}
	.ls-wide {
		letter-spacing: 0.12em;
	}
</style>
