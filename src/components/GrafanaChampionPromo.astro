---
import { GRAFANA } from '../consts';
---

<div class="grafana-promo card border-0 shadow-sm overflow-hidden">
	<div class="card-body p-4 p-md-4">
		<div class="row align-items-center g-4">
			<div class="col-sm-auto text-center">
				<figure class="mb-0 grafana-promo__figure">
					<a
						href={GRAFANA.champions}
						target="_blank"
						rel="noopener noreferrer"
						class="grafana-promo__logo-link d-inline-block"
					>
						<img
							class="grafana-promo__logo img-fluid"
							src={GRAFANA.championLogo}
							alt="Grafana Champion"
							width="625"
							height="622"
							loading="lazy"
							decoding="async"
						/>
					</a>
					<figcaption class="small text-body-secondary mt-2 mb-0 px-1">
						Official Grafana Champion artwork — same asset as on{' '}
						<a href={GRAFANA.site} target="_blank" rel="noopener noreferrer">grafana.com</a>
					</figcaption>
					<!-- Tiny friendly bot — original doodle, not Grafana IP -->
					<div class="grafana-promo__buddy mt-3" aria-hidden="true">
						<svg
							class="grafana-promo__bot"
							viewBox="0 0 96 88"
							xmlns="http://www.w3.org/2000/svg"
							focusable="false"
						>
							<ellipse cx="48" cy="58" rx="34" ry="28" fill="#2a2a2a" />
							<circle cx="38" cy="48" r="6" fill="#f46800" />
							<circle cx="58" cy="48" r="6" fill="#f46800" />
							<path
								d="M40 38 Q48 34 56 38"
								stroke="#f46800"
								stroke-width="2"
								fill="none"
								stroke-linecap="round"
							/>
							<line x1="48" y1="42" x2="48" y2="24" stroke="#f46800" stroke-width="3" stroke-linecap="round" />
							<circle cx="48" cy="20" r="5" fill="#f46800" />
							<path
								d="M34 62 L42 56 L48 60 L54 52 L62 58"
								stroke="#f46800"
								stroke-width="2"
								fill="none"
								stroke-linecap="round"
							/>
						</svg>
						<span class="grafana-promo__buddy-label">your metrics pal</span>
					</div>
				</figure>
			</div>
			<div class="col">
				<p class="text-uppercase small fw-semibold text-primary mb-1 ls-wide">Community</p>
				<h2 class="h5 fw-bold mb-2">Grafana Champion</h2>
				<p class="text-body-secondary small mb-3 mb-md-4">
					I am part of the{' '}
					<a href={GRAFANA.champions} target="_blank" rel="noopener noreferrer">Grafana Champions</a>
					program — helping folks get more from observability, dashboards, and the open source ecosystem around
					<a href={GRAFANA.site} target="_blank" rel="noopener noreferrer">Grafana</a>.
				</p>
				<div class="d-flex flex-wrap gap-2">
					<a class="btn btn-sm btn-primary" href={GRAFANA.site} target="_blank" rel="noopener noreferrer">
						Grafana.com
					</a>
					<a
						class="btn btn-sm btn-outline-secondary"
						href={GRAFANA.champions}
						target="_blank"
						rel="noopener noreferrer"
					>
						Champions program
					</a>
				</div>
			</div>
		</div>
	</div>
</div>

<style>
	.grafana-promo {
		background: linear-gradient(135deg, #fafafa 0%, #f0f4f8 100%);
		border: 1px solid rgba(0, 0, 0, 0.06) !important;
	}
	.grafana-promo__figure {
		max-width: 14rem;
		margin-left: auto;
		margin-right: auto;
	}
	.grafana-promo__logo-link {
		text-decoration: none;
		border-radius: 0.5rem;
		transition: transform 0.15s ease, filter 0.15s ease;
	}
	.grafana-promo__logo-link:hover {
		transform: scale(1.02);
		filter: brightness(1.03);
	}
	.grafana-promo__logo {
		display: block;
		margin: 0 auto;
		max-height: 10rem;
		width: auto;
		height: auto;
		object-fit: contain;
		filter: drop-shadow(0 4px 14px rgba(0, 0, 0, 0.08));
	}
	.grafana-promo__buddy {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
		opacity: 0.92;
	}
	.grafana-promo__bot {
		width: 3.25rem;
		height: auto;
		display: block;
	}
	.grafana-promo__buddy-label {
		font-size: 0.7rem;
		color: var(--bs-secondary-color);
		font-style: italic;
		letter-spacing: 0.02em;
	}
	.ls-wide {
		letter-spacing: 0.12em;
	}
</style>
