---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE, GITHUB_USERNAME } from '../consts';
---

<header>
	<div class="header-inner">
		<nav>
			<h2 class="site-title"><a href="/">{SITE_TITLE}</a></h2>
			<div class="internal-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/about/">About</HeaderLink>
			</div>
			<div class="social-links">
				<a
					href={`https://github.com/${GITHUB_USERNAME}`}
					target="_blank"
					rel="noopener noreferrer"
					class="icon-link"
				>
					<span class="sr-only">GitHub profile</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
						><path
							fill="currentColor"
							d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
						></path></svg
					>
				</a>
			</div>
		</nav>
	</div>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		margin: 0;
		background: rgba(255, 255, 255, 0.82);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(var(--gray-light), 0.95);
		box-shadow: 0 1px 0 rgba(15, 23, 42, 0.04);
	}
	.header-inner {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: 0 1rem;
	}
	.site-title {
		margin: 0;
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: -0.03em;
	}
	.site-title a {
		color: rgb(var(--black));
		text-decoration: none;
	}
	.site-title a:hover {
		color: var(--accent);
	}
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 3.25rem;
	}
	nav a {
		padding: 0.85rem 0.65rem;
		color: rgb(var(--gray-dark));
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}
	nav a:hover {
		color: var(--accent);
	}
	nav a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	.icon-link {
		padding: 0.5rem !important;
		border-radius: 8px;
		color: rgb(var(--gray-dark)) !important;
	}
	.icon-link:hover {
		background: var(--accent-soft);
		color: var(--accent) !important;
		border-bottom-color: transparent !important;
	}
</style>
