---
import { CONTACT, SITE_URL } from '../consts';

const web3Key = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
const useWeb3 = web3Key.length > 0;
const formSubmitAction = `https://formsubmit.co/${encodeURIComponent(CONTACT.email)}`;
const nextUrl = `${SITE_URL.replace(/\/$/, '')}/services/?thanks=1`;
---

<div class="services-inquiry-form">
	{
		useWeb3 ? (
			<>
				<form id="services-inquiry-web3" class="needs-validation" novalidate>
					<div class="row g-3">
						<div class="col-md-6">
							<label class="form-label" for="si-name">
								Name <span class="text-danger">*</span>
							</label>
							<input
								type="text"
								class="form-control"
								id="si-name"
								name="name"
								required
								autocomplete="name"
							/>
						</div>
						<div class="col-md-6">
							<label class="form-label" for="si-email">
								Email <span class="text-danger">*</span>
							</label>
							<input
								type="email"
								class="form-control"
								id="si-email"
								name="email"
								required
								autocomplete="email"
							/>
						</div>
						<div class="col-12">
							<label class="form-label" for="si-org">Organization or site name</label>
							<input
								type="text"
								class="form-control"
								id="si-org"
								name="organization"
								autocomplete="organization"
							/>
						</div>
						<div class="col-12">
							<span class="form-label d-block mb-2">
								What are you looking for? <span class="text-danger">*</span>
								<span class="text-body-secondary fw-normal small d-block">Select all that apply.</span>
							</span>
							<div class="row row-cols-1 row-cols-sm-2 g-2">
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="si-svc-design" name="svc_web_design" value="Yes" />
										<label class="form-check-label" for="si-svc-design">Web design</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="si-svc-mgmt" name="svc_site_management" value="Yes" />
										<label class="form-check-label" for="si-svc-mgmt">Site management &amp; updates</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="si-svc-host" name="svc_hosting" value="Yes" />
										<label class="form-check-label" for="si-svc-host">Hosting</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="si-svc-infra" name="svc_infrastructure" value="Yes" />
										<label class="form-check-label" for="si-svc-infra">Infrastructure / IT consulting</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="si-svc-consulting" name="svc_consulting" value="Yes" />
										<label class="form-check-label" for="si-svc-consulting">Consulting services</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="si-svc-implementation" name="svc_implementation" value="Yes" />
										<label class="form-check-label" for="si-svc-implementation">Implementation services</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="si-svc-dev" name="svc_development" value="Yes" />
										<label class="form-check-label" for="si-svc-dev">Development / automation</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="si-svc-other" name="svc_other" value="Yes" />
										<label class="form-check-label" for="si-svc-other">Other (describe below)</label>
									</div>
								</div>
							</div>
						</div>
						<div class="col-md-6">
							<label class="form-label" for="si-timeline">
								Target timeline <span class="text-danger">*</span>
							</label>
							<select class="form-select" id="si-timeline" name="timeline" required>
								<option value="" selected disabled>Select…</option>
								<option value="ASAP / urgent">ASAP / urgent</option>
								<option value="Within 1 month">Within 1 month</option>
								<option value="1–3 months">1–3 months</option>
								<option value="3–6 months">3–6 months</option>
								<option value="Flexible / exploring">Flexible / exploring</option>
							</select>
						</div>
						<div class="col-md-6">
							<label class="form-label" for="si-budget">Budget range</label>
							<select class="form-select" id="si-budget" name="budget">
								<option value="" selected>Prefer to discuss</option>
								<option value="Under $2,500">Under $2,500</option>
								<option value="$2,500 – $10,000">$2,500 – $10,000</option>
								<option value="$10,000 – $25,000">$10,000 – $25,000</option>
								<option value="$25,000+">$25,000+</option>
								<option value="Not sure yet">Not sure yet</option>
							</select>
						</div>
						<div class="col-12">
							<label class="form-label" for="si-url">Existing website (if any)</label>
							<input
								type="url"
								class="form-control"
								id="si-url"
								name="existing_website"
								placeholder="https://"
								autocomplete="url"
							/>
						</div>
						<div class="col-12">
							<label class="form-label" for="si-details">
								Project details <span class="text-danger">*</span>
							</label>
							<textarea
								class="form-control"
								id="si-details"
								name="project_details"
								rows="5"
								required
								placeholder="Goals, audience, tech preferences, compliance needs, or anything else that helps scope the work."
							/>
						</div>
					</div>
					<div id="services-inquiry-status" class="mt-3 mb-0" role="status" aria-live="polite" />
					<button type="submit" class="btn btn-primary mt-3" id="services-inquiry-submit">
						Submit services inquiry
					</button>
				</form>
				<script is:inline define:vars={{ web3Key }}>
					(function () {
						function serviceLines(fd) {
							var lines = [];
							var map = [
								['svc_web_design', 'Web design'],
								['svc_site_management', 'Site management & updates'],
								['svc_hosting', 'Hosting'],
								['svc_infrastructure', 'Infrastructure / IT consulting'],
								['svc_consulting', 'Consulting services'],
								['svc_implementation', 'Implementation services'],
								['svc_development', 'Development / automation'],
								['svc_other', 'Other'],
							];
							for (var i = 0; i < map.length; i++) {
								if (fd.get(map[i][0])) lines.push('- ' + map[i][1]);
							}
							return lines.length ? lines.join('\n') : '';
						}

						function buildMessage(fd) {
							var services = serviceLines(fd);
							var parts = [
								'## Services inquiry (briangates.tech/services)',
								'',
								'### Services of interest',
								services || '(none selected)',
								'',
								'### Organization',
								fd.get('organization') || '(not provided)',
								'',
								'### Timeline',
								fd.get('timeline') || '',
								'',
								'### Budget',
								fd.get('budget') || '(prefer to discuss)',
								'',
								'### Existing website',
								fd.get('existing_website') || '(none)',
								'',
								'### Project details',
								fd.get('project_details') || '',
							];
							return parts.join('\n');
						}

						var form = document.getElementById('services-inquiry-web3');
						var statusEl = document.getElementById('services-inquiry-status');
						var submitBtn = document.getElementById('services-inquiry-submit');
						if (!form || !statusEl || !submitBtn) return;

						form.addEventListener('submit', async function (e) {
							e.preventDefault();
							var fd = new FormData(form);
							if (!serviceLines(fd)) {
								statusEl.innerHTML =
									'<div class="alert alert-warning mb-0">Please select at least one type of service.</div>';
								return;
							}
							if (!form.checkValidity()) {
								form.classList.add('was-validated');
								statusEl.innerHTML = '';
								return;
							}
							statusEl.innerHTML = '';
							submitBtn.disabled = true;
							var prevText = submitBtn.textContent;
							submitBtn.textContent = 'Sending…';

							var payload = {
								access_key: web3Key,
								name: fd.get('name'),
								email: fd.get('email'),
								subject: 'Services inquiry — briangates.tech',
								message: buildMessage(fd),
							};

							try {
								var res = await fetch('https://api.web3forms.com/submit', {
									method: 'POST',
									headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
									body: JSON.stringify(payload),
								});
								var data = await res.json().catch(function () {
									return {};
								});
								if (data.success) {
									statusEl.innerHTML =
										'<div class="alert alert-success mb-0">Thanks — your inquiry was sent. I will follow up by email.</div>';
									form.reset();
									form.classList.remove('was-validated');
								} else {
									statusEl.innerHTML =
										'<div class="alert alert-danger mb-0">Something went wrong. Please try again or email directly.</div>';
								}
							} catch {
								statusEl.innerHTML =
									'<div class="alert alert-danger mb-0">Network error. Please email directly.</div>';
							} finally {
								submitBtn.disabled = false;
								submitBtn.textContent = prevText;
							}
						});
					})();
				</script>
			</>
		) : (
			<>
				<form id="services-inquiry-fs" action={formSubmitAction} method="POST">
					<input type="hidden" name="_next" value={nextUrl} />
					<input type="hidden" name="_subject" value="Services inquiry — briangates.tech" />
					<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />
					<div class="row g-3">
						<div class="col-md-6">
							<label class="form-label" for="sfs-name">
								Name <span class="text-danger">*</span>
							</label>
							<input type="text" class="form-control" id="sfs-name" name="name" required autocomplete="name" />
						</div>
						<div class="col-md-6">
							<label class="form-label" for="sfs-email">
								Email <span class="text-danger">*</span>
							</label>
							<input type="email" class="form-control" id="sfs-email" name="email" required autocomplete="email" />
						</div>
						<div class="col-12">
							<label class="form-label" for="sfs-org">Organization or site name</label>
							<input type="text" class="form-control" id="sfs-org" name="organization" autocomplete="organization" />
						</div>
						<div class="col-12">
							<span class="form-label d-block mb-2">
								What are you looking for? <span class="text-danger">*</span>
								<span class="text-body-secondary fw-normal small d-block">Select all that apply.</span>
							</span>
							<div class="row row-cols-1 row-cols-sm-2 g-2">
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="sfs-svc-design" name="svc_web_design" value="Yes" />
										<label class="form-check-label" for="sfs-svc-design">Web design</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="sfs-svc-mgmt" name="svc_site_management" value="Yes" />
										<label class="form-check-label" for="sfs-svc-mgmt">Site management &amp; updates</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="sfs-svc-host" name="svc_hosting" value="Yes" />
										<label class="form-check-label" for="sfs-svc-host">Hosting</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="sfs-svc-infra" name="svc_infrastructure" value="Yes" />
										<label class="form-check-label" for="sfs-svc-infra">Infrastructure / IT consulting</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="sfs-svc-consulting" name="svc_consulting" value="Yes" />
										<label class="form-check-label" for="sfs-svc-consulting">Consulting services</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="sfs-svc-implementation" name="svc_implementation" value="Yes" />
										<label class="form-check-label" for="sfs-svc-implementation">Implementation services</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="sfs-svc-dev" name="svc_development" value="Yes" />
										<label class="form-check-label" for="sfs-svc-dev">Development / automation</label>
									</div>
								</div>
								<div class="col">
									<div class="form-check">
										<input class="form-check-input" type="checkbox" id="sfs-svc-other" name="svc_other" value="Yes" />
										<label class="form-check-label" for="sfs-svc-other">Other (describe below)</label>
									</div>
								</div>
							</div>
						</div>
						<div class="col-md-6">
							<label class="form-label" for="sfs-timeline">
								Target timeline <span class="text-danger">*</span>
							</label>
							<select class="form-select" id="sfs-timeline" name="timeline" required>
								<option value="" selected disabled>Select…</option>
								<option value="ASAP / urgent">ASAP / urgent</option>
								<option value="Within 1 month">Within 1 month</option>
								<option value="1–3 months">1–3 months</option>
								<option value="3–6 months">3–6 months</option>
								<option value="Flexible / exploring">Flexible / exploring</option>
							</select>
						</div>
						<div class="col-md-6">
							<label class="form-label" for="sfs-budget">Budget range</label>
							<select class="form-select" id="sfs-budget" name="budget">
								<option value="" selected>Prefer to discuss</option>
								<option value="Under $2,500">Under $2,500</option>
								<option value="$2,500 – $10,000">$2,500 – $10,000</option>
								<option value="$10,000 – $25,000">$10,000 – $25,000</option>
								<option value="$25,000+">$25,000+</option>
								<option value="Not sure yet">Not sure yet</option>
							</select>
						</div>
						<div class="col-12">
							<label class="form-label" for="sfs-url">Existing website (if any)</label>
							<input type="url" class="form-control" id="sfs-url" name="existing_website" placeholder="https://" autocomplete="url" />
						</div>
						<div class="col-12">
							<label class="form-label" for="sfs-details">
								Project details <span class="text-danger">*</span>
							</label>
							<textarea
								class="form-control"
								id="sfs-details"
								name="project_details"
								rows="5"
								required
								placeholder="Goals, audience, tech preferences, compliance needs, or anything else that helps scope the work."
							/>
						</div>
					</div>
					<div id="services-inquiry-fs-error" class="text-danger small mt-2 d-none" role="alert">
						Please select at least one type of service.
					</div>
					<button type="submit" class="btn btn-primary mt-3">Submit services inquiry</button>
				</form>
				<p class="form-text text-body-secondary small mt-3 mb-0">
					Delivered via FormSubmit. Select at least one service above. First submission may require a one-time email
					verification.
				</p>
				<script is:inline>
					(function () {
						var form = document.getElementById('services-inquiry-fs');
						var err = document.getElementById('services-inquiry-fs-error');
						if (!form || !err) return;
						form.addEventListener('submit', function (e) {
							var boxes = form.querySelectorAll('input[type="checkbox"][name^="svc_"]');
							var any = false;
							for (var i = 0; i < boxes.length; i++) {
								if (boxes[i].checked) {
									any = true;
									break;
								}
							}
							if (!any) {
								e.preventDefault();
								err.classList.remove('d-none');
							} else {
								err.classList.add('d-none');
							}
						});
					})();
				</script>
			</>
		)
	}
</div>
