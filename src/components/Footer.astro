---
import { CONTACT, GITHUB_USERNAME } from '../consts';

const today = new Date();
---

<footer>
	<p class="footer-line">&copy; {today.getFullYear()} Brian Gates</p>
	<p class="footer-line">
		<a href={`https://github.com/${GITHUB_USERNAME}`} target="_blank" rel="noopener noreferrer">GitHub</a>
		{
			CONTACT.linkedin && (
				<>
					<span class="sep">·</span>
					<a href={CONTACT.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
				</>
			)
		}
		<span class="sep">·</span>
		<a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
	</p>
</footer>
<style>
	footer {
		padding: 2em 1em 3em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.95rem;
	}
	.footer-line {
		margin: 0.35rem 0;
	}
	.sep {
		margin: 0 0.5rem;
		opacity: 0.6;
	}
	footer a {
		color: rgb(var(--gray-dark));
	}
	footer a:hover {
		color: var(--accent);
	}
</style>
