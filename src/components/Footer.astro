---
/**
 * Single footer + end-of-body scripts for the whole site.
 * Included only from BaseLayout.astro (every route uses BaseLayout or SimplePage → BaseLayout).
 */
import { CONTACT, GITHUB_USERNAME } from '../consts';

const today = new Date();
/** Matches Faro `appId` in Grafana → Settings → Source maps (required for uploaded maps to apply). */
const faroAppId = import.meta.env.PUBLIC_FARO_APP_ID ?? '';
const faroAppVersion = import.meta.env.PUBLIC_FARO_APP_VERSION ?? '1.0.0';
---

<footer class="footer-portfolio mt-auto border-top bg-body-tertiary">
	<div class="container py-4 px-3">
		<p class="text-center text-body-secondary small mb-2 mb-md-0">
			&copy; {today.getFullYear()} Brian Gates
		</p>
		<p class="text-center text-body-secondary small mb-0">
			<a class="link-secondary text-decoration-none" href={`https://github.com/${GITHUB_USERNAME}`} target="_blank" rel="noopener noreferrer">GitHub</a>
			{
				CONTACT.linkedin && (
					<>
						<span class="text-secondary mx-2">·</span>
						<a class="link-secondary text-decoration-none" href={CONTACT.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
					</>
				)
			}
			<span class="text-secondary mx-2">·</span>
			<a class="link-secondary text-decoration-none text-break" href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
		</p>
	</div>
</footer>

<!-- Grafana Faro RUM — matches Web SDK quickstart + optional app.id/version from build (source maps). -->
<script is:inline define:vars={{ faroAppId, faroAppVersion }}>
	(function () {
		var webSdkScript = document.createElement('script');
		// Fetch the latest 2.x.x Web SDK from the CDN (see Grafana Frontend Observability quickstart).
		webSdkScript.src =
			'https://unpkg.com/@grafana/faro-web-sdk@2/dist/bundle/faro-web-sdk.iife.js';

		webSdkScript.onload = function () {
			var app = {
				name: 'briangates.tech',
				version: faroAppVersion,
				environment: 'production',
			};
			if (faroAppId) {
				app.id = faroAppId;
			}
			window.GrafanaFaroWebSdk.initializeFaro({
				url: 'https://faro-collector-prod-us-east-0.grafana.net/collect/d7755bacae27e72368c37cf1a31a302c',
				app: app,
				sessionTracking: {
					samplingRate: 1,
					persistent: true,
				},
			});

			// Load tracing after the Web SDK has initialized (required order per Grafana docs).
			var webTracingScript = document.createElement('script');
			webTracingScript.src =
				'https://unpkg.com/@grafana/faro-web-tracing@2/dist/bundle/faro-web-tracing.iife.js';

			webTracingScript.onload = function () {
				window.GrafanaFaroWebSdk.faro.instrumentations.add(
					new window.GrafanaFaroWebTracing.TracingInstrumentation()
				);
			};

			document.head.appendChild(webTracingScript);
		};

		document.head.appendChild(webSdkScript);
	})();
</script>

<script
	is:inline
	src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
	integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
	crossorigin="anonymous"
></script>
