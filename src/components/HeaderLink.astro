---
import type { HTMLAttributes } from 'astro/types';
import { hrefAbout, hrefHome, isAboutPage } from '../utils/sitePaths';

type Props = Omit<HTMLAttributes<'a'>, 'href'> & {
	variant: 'home' | 'about';
};

const { class: className, variant, ...props } = Astro.props;

const pathname = Astro.url.pathname;
const resolvedHref = variant === 'home' ? hrefHome(pathname) : hrefAbout(pathname);
const isActive = variant === 'home' ? !isAboutPage(pathname) : isAboutPage(pathname);
---

<a href={resolvedHref} class:list={[className, 'nav-link', { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a.nav-link {
		text-decoration: none;
	}
</style>
