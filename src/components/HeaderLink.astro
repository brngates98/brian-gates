---
import type { HTMLAttributes } from 'astro/types';
import { sitePath } from '../utils/sitePath';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;

const hrefStr = typeof href === 'string' ? href : '';
const resolvedHref = sitePath(hrefStr);

const base = import.meta.env.BASE_URL;
let pathname = Astro.url.pathname.replace(base, '') || '/';
if (!pathname.startsWith('/')) pathname = `/${pathname}`;

/** Normalize for trailingSlash: 'always'. */
function withSlash(p: string) {
	if (p === '/' || p === '') return '/';
	return p.endsWith('/') ? p : `${p}/`;
}

const pathNorm = withSlash(pathname);
const hrefNorm = withSlash(hrefStr.startsWith('/') ? hrefStr : `/${hrefStr}`);

const isActive = pathNorm === hrefNorm;
---

<a href={resolvedHref} class:list={[className, 'nav-link', { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a.nav-link {
		text-decoration: none;
	}
</style>
