---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      {/* Hero Section */}
      <section style="padding: 2rem 0; text-align: center;">
        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Hi, I'm Brian Gates</h1>
        <p style="font-size: 1.25rem; color: #666;">Web Developer & Designer</p>
        <p style="margin-top: 1rem; max-width: 600px; margin-left: auto; margin-right: auto;">
          Welcome to my portfolio! I build modern, accessible, and performant web experiences. Explore my work and get in touch if you'd like to collaborate.
        </p>
      </section>

      {/* Skills Section */}
      <section style="padding: 2rem 0;">
        <h2>Skills</h2>
        <ul style="display: flex; flex-wrap: wrap; gap: 1rem; list-style: none; padding: 0;">
          <li style="background: #f3f3f3; padding: 0.5rem 1rem; border-radius: 5px;">HTML</li>
          <li style="background: #f3f3f3; padding: 0.5rem 1rem; border-radius: 5px;">CSS</li>
          <li style="background: #f3f3f3; padding: 0.5rem 1rem; border-radius: 5px;">JavaScript</li>
          <li style="background: #f3f3f3; padding: 0.5rem 1rem; border-radius: 5px;">TypeScript</li>
          <li style="background: #f3f3f3; padding: 0.5rem 1rem; border-radius: 5px;">Astro</li>
          <li style="background: #f3f3f3; padding: 0.5rem 1rem; border-radius: 5px;">React</li>
          <li style="background: #f3f3f3; padding: 0.5rem 1rem; border-radius: 5px;">Node.js</li>
        </ul>
      </section>

      {/* Projects Section */}
      <section style="padding: 2rem 0;">
        <h2>Projects</h2>
        <div style="display: flex; flex-wrap: wrap; gap: 2rem;">
          <div style="flex: 1 1 250px; background: #fafafa; padding: 1rem; border-radius: 8px; box-shadow: 0 2px 8px #0001;">
            <h3>Project One</h3>
            <p>A brief description of your project. What does it do? What tech did you use?</p>
            <a href="#" style="color: #0070f3;">View Project</a>
          </div>
          <div style="flex: 1 1 250px; background: #fafafa; padding: 1rem; border-radius: 8px; box-shadow: 0 2px 8px #0001;">
            <h3>Project Two</h3>
            <p>A brief description of your project. What does it do? What tech did you use?</p>
            <a href="#" style="color: #0070f3;">View Project</a>
          </div>
          <div style="flex: 1 1 250px; background: #fafafa; padding: 1rem; border-radius: 8px; box-shadow: 0 2px 8px #0001;">
            <h3>Project Three</h3>
            <p>A brief description of your project. What does it do? What tech did you use?</p>
            <a href="#" style="color: #0070f3;">View Project</a>
          </div>
        </div>
      </section>

      {/* Contact Section */}
      <section style="padding: 2rem 0; text-align: center;">
        <h2>Contact</h2>
        <p>Interested in working together or have a question? Reach out!</p>
        <a href="mailto:brian@briangates.tech" style="display: inline-block; margin-top: 1rem; padding: 0.75rem 1.5rem; background: #0070f3; color: #fff; border-radius: 5px; text-decoration: none;">Email Me</a>
        <div style="margin-top: 2rem;">
          <a href="#" style="margin: 0 1rem; color: #0070f3; text-decoration: underline;">Resume (coming soon)</a>
          <a href="#" style="margin: 0 1rem; color: #0070f3; text-decoration: underline;">Projects (coming soon)</a>
          <a href="#" style="margin: 0 1rem; color: #0070f3; text-decoration: underline;">LinkedIn (coming soon)</a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
