---
import { getCollection } from 'astro:content';
import SimplePage from '../../layouts/SimplePage.astro';
import { hrefAbout, hrefContact, hrefHome, hrefServices } from '../../utils/sitePaths';

const pathname = Astro.url.pathname;

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(d: Date): string {
	return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<SimplePage
	title="Blog — Brian Gates"
	description="Tech articles, how-tos, and notes from Brian Gates."
>
	<h1 class="display-6 fw-bold border-bottom pb-3 mb-4">Blog</h1>
	<p class="lead text-body-secondary mb-4">
		Short posts on tech I care about — articles, how-tos, and whatever else is worth writing down. No strict cadence;
		new pieces show up when there is something useful to share.
	</p>
	<ul class="list-unstyled">
		{
			posts.map((post) => (
				<li class="mb-4 pb-4 border-bottom border-secondary-subtle">
					<p class="small text-body-secondary mb-1">
						<time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
					</p>
					<h2 class="h5 mb-2">
						<a class="link-dark text-decoration-none" href={`./${post.slug}/`}>
							{post.data.title}
						</a>
					</h2>
					<p class="text-body-secondary small mb-0">{post.data.description}</p>
				</li>
			))
		}
	</ul>
	<p class="mb-0 d-flex flex-wrap gap-2">
		<a class="btn btn-outline-primary btn-sm" href={hrefHome(pathname)}>← Home</a>
		<a class="btn btn-outline-secondary btn-sm" href={hrefAbout(pathname)}>About</a>
		<a class="btn btn-outline-secondary btn-sm" href={hrefServices(pathname)}>Services</a>
		<a class="btn btn-outline-secondary btn-sm" href={hrefContact(pathname)}>Contact</a>
	</p>
</SimplePage>
