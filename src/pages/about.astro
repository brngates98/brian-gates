---
import SimplePage from '../layouts/SimplePage.astro';
import { CONTACT, GITHUB_USERNAME } from '../consts';
---

<SimplePage
	title="About — Brian Gates"
	description="Systems engineer and developer — background, interests, and how I work."
>
	<h1>About</h1>
	<p>
		I am a systems engineer and developer focused on reliable infrastructure, automation, and
		observability. I have been recognized as a Grafana Champion and enjoy turning messy operational
		data into dashboards people actually use.
	</p>
	<p>
		Technically, I spend a lot of time with Kubernetes, Linux, Python, and Go, building pipelines and
		platform pieces that hold up under load. I care about clear runbooks, measurable SLOs, and
		reducing toil.
	</p>
	<p>
		Away from the terminal I am often under the hood of a classic car or experimenting with how to
		visualize something in Grafana a little more clearly.
	</p>
	<p>
		<a href={`https://github.com/${GITHUB_USERNAME}`} target="_blank" rel="noopener noreferrer">
			GitHub — {`@${GITHUB_USERNAME}`}
		</a>
		{
			CONTACT.grafanaAgents && (
				<>
					{' '}
					·{' '}
					<a href={CONTACT.grafanaAgents} target="_blank" rel="noopener noreferrer">
						GrafanaAgents
					</a>
				</>
			)
		}
	</p>
	<p><a href="/">← Home</a></p>
</SimplePage>
